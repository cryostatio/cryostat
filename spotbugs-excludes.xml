<FindBugsFilter>
  <Match>
    <SuperClass name="io.quarkus.hibernate.orm.panache.PanacheEntity"/>
    <Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE"/>
  </Match>
  <Match>
    <!-- These are almost always false positives due to bytecode particulars -->
    <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
  </Match>
  <Match>
    <!-- False positives with try-with-resources after dereferencing -->
    <Bug pattern="RCN_REDUNDANT_NULLCHECK_WOULD_HAVE_BEEN_A_NPE"/>
  </Match>
</FindBugsFilter>
